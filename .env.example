# URL project Supabase (local hoặc cloud)
NEXT_PUBLIC_SUPABASE_URL=

# Key public phía client. Dùng MỘT trong hai:
#  - Local (Supabase CLI): anon JWT  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#  - Cloud (key mới):      publishable → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# BẮT BUỘC — service role / secret key (SECRET phía server, KHÔNG NEXT_PUBLIC_).
# Dùng cho: admin THÊM thành viên (tạo tài khoản) + scripts/seed.sh.
# Local: service_role JWT (supabase status). Cloud: secret key (sb_secret_...).
SUPABASE_SERVICE_ROLE_KEY=

# URL site (dùng cho redirect/site). Local: http://localhost:3000 (hoặc 3001). Cloud: domain deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
