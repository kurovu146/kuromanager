# URL project Supabase (local hoặc cloud)
NEXT_PUBLIC_SUPABASE_URL=

# Key public phía client. Dùng MỘT trong hai:
#  - Local (Supabase CLI): anon JWT  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#  - Cloud (key mới):      publishable → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# CHỈ dùng cho scripts/seed.sh (tạo admin qua admin API). App KHÔNG dùng.
# Local: service_role JWT. Cloud: secret key (sb_secret_...). Có thể bỏ nếu tạo admin qua Dashboard.
SUPABASE_SERVICE_ROLE_KEY=

# URL site (dùng sinh link mời). Local: http://localhost:3000 (hoặc 3001). Cloud: domain deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — gửi email mời thành viên (SECRET phía server, KHÔNG NEXT_PUBLIC_).
# Bỏ trống = không gửi email, app vẫn trả link để copy tay.
RESEND_API_KEY=
# RESEND_FROM='KuroManager <noreply@your-domain.com>'  # cần verify domain trên Resend
